; Claude on the Amiga - in-guest integration test (AROS m68k ROM boot)
; AROS boots this volume and its ROM-internal shell runs S:startup-sequence.
; SYS: is the boot volume (this directory, shared/), reachable on the host.
; bsdsocket shares the host network identity, so the host's own LAN IP
; (192.168.0.156 here) reaches the mock proxy that run_test.sh starts before
; the emulator launches. run_test.sh rewrites this IP to the live host IP.

echo "*E[claude test] boot OK, starting client*E[0m" >SYS:claude.log

; --- 1. one-shot chat through the proxy (expects the mock hello reply) ---
echo "=== chat ===" >>SYS:claude.log
SYS:claude --verbose "Say hello from the Amiga" --proxy 127.0.0.1:8791 >>SYS:claude.log

; --- 2. tool-use loop: the mock returns a write_file tool_use, the client
;        executes it locally (--yes skips the y/N gate for this headless run)
;        and writes SYS:claude_tool_out.txt, then loops to end_turn. ---
echo "=== tool-use ===" >>SYS:claude.log
SYS:claude "TOOLTEST write the file" --proxy 127.0.0.1:8791 --yes >>SYS:claude.log

echo "=== done ===" >>SYS:claude.log
echo "claude test complete" >SYS:claude_done.txt
