--- src-lua/lua-5.4.7/src/luaconf.h	2024-06-13 17:15:10.000000000 -0500
+++ patches/luaconf-amiga.h	2026-07-03 22:19:45.037953668 -0500
@@ -8,6 +8,37 @@
 #ifndef luaconf_h
 #define luaconf_h
 
+/*
+** ===================================================================
+** AmigaOS m68k port (rustchain-amiga / lua/, see lua/README.md)
+**
+** This file is stock Lua 5.4.7 luaconf.h with exactly one functional
+** change: LUA_32BITS is forced to 1 below, in the "Number types"
+** section. Everything else is untouched upstream Lua.
+**
+** Why: the default Lua number config is 'long long' (64-bit integer)
+** and 'double' (64-bit float). On m68k AmigaOS with the libnix C
+** library and gcc -m68020 (no 68881 FPU assumed), 64-bit integer
+** ops need __divdi3/__moddi3 etc from libgcc, and double math is
+** software-emulated - both slow and, per prior bebbo-gcc miner
+** experience on this repo, a source of subtle miscompiles at low
+** optimization/CPU settings. LUA_32BITS switches lua_Integer to
+** plain 'int' (32-bit, native m68k register width, real hardware
+** MULS/DIVS) and lua_Number to 'float' (32-bit, still soft-float
+** without an FPU but half the work of double). See lua/README.md
+** for the honest tradeoffs (no 64-bit integers, ~7 significant
+** digits of float precision instead of ~15).
+**
+** No other AmigaOS-specific macros are needed: this file does not
+** define LUA_USE_LINUX / LUA_USE_POSIX / LUA_USE_DLOPEN / LUA_DL_DLL
+** / LUA_USE_C89, so loadlib.c's dlopen path, lua.c's isatty() path,
+** and the C89 snprintf fallback are all correctly skipped - Lua's
+** own "unknown platform" defaults (assume stdin is a tty, dynamic
+** libraries disabled, use real snprintf) are exactly right for
+** libnix, which is C99-capable.
+** ===================================================================
+*/
+
 #include <limits.h>
 #include <stddef.h>
 
@@ -121,8 +152,9 @@
 
 /*
 @@ LUA_32BITS enables Lua with 32-bit integers and 32-bit floats.
+** AmigaOS/m68k port: forced on, see the file header comment above.
 */
-#define LUA_32BITS	0
+#define LUA_32BITS	1
 
 
 /*
