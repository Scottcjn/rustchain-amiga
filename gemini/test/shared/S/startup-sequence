; Gemini on the Amiga - in-guest integration test (AROS m68k ROM boot)
; AROS boots this volume and its ROM-internal shell runs S:startup-sequence.
; SYS: is the boot volume (this directory, shared/), reachable on the host.
; bsdsocket shares the host network identity, so the guest's 127.0.0.1
; reaches the host-side proxy bridge that run_test.sh starts before the
; emulator launches. The bridge in turn does real TLS to a canned local
; Gemini capsule (also on the host, 127.0.0.1) so this test is deterministic.

echo "gemini test: boot OK, starting client" >SYS:gemini.log
echo "=== fetch canned capsule via proxy ===" >>SYS:gemini.log
SYS:gemini gemini://127.0.0.1:19811/ --proxy 127.0.0.1:8811 -1 -v >>SYS:gemini.log

echo "=== done ===" >>SYS:gemini.log
echo "gemini test complete" >SYS:gemini_done.txt
